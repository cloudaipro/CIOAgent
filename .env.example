# Copy to .env and fill in. Get a token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# STRONGLY RECOMMENDED: lock the bot to your own chat(s). Comma-separated Telegram
# chat ids. Unset = the bot answers ANYONE who finds it (reads your portfolio,
# imports CSVs, spends NIM credits via /committee). Send /start and check the logs
# for your chat id, or ask @userinfobot.
# CIO_ALLOWED_CHATS=123456789

# OpenAI API — CIO tries OpenAI first (gpt-5.5-2026-04-23), then falls back to
# Claude Opus then NVIDIA NIM as daily token budgets are exhausted.
# Get a key at platform.openai.com
OPENAI_API_KEY=

# NVIDIA NIM (committee agents set to service: nim) — get a key at build.nvidia.com
NVIDIA_API_KEY=
# Committee execution: on = parallel (default), off = one agent at a time
# CIO_PARALLEL=on
# CIO_MAX_CONCURRENCY=8
# CIO_MODELS_CONFIG=config/committee_models.yaml

# Optional: pin the model the agent uses (defaults to Claude Code's default).
# CIO_MODEL=claude-haiku-4-5
# CFO_MODEL=claude-haiku-4-5  # still honored as fallback

# Daily digest time (local timezone). Set CIO_DIGEST_HOUR=off to disable.
# CIO_DIGEST_HOUR=8
# CIO_DIGEST_MINUTE=0
# CFO_DIGEST_HOUR / CFO_DIGEST_MINUTE still honored as fallback (back-compat)
