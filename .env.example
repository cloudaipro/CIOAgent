# Copy to .env and fill in. Get a token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# STRONGLY RECOMMENDED: lock the bot to your own chat(s). Comma-separated Telegram
# chat ids. Unset = the bot answers ANYONE who finds it (reads your portfolio,
# imports CSVs, spends NIM credits via /committee). Send /start and check the logs
# for your chat id, or ask @userinfobot.
# CIO_ALLOWED_CHATS=123456789

# OpenAI API — CIO tries OpenAI first (gpt-5.5-2026-04-23), then falls back to
# Claude Opus then NVIDIA NIM as daily token budgets are exhausted.
# Get a key at platform.openai.com
OPENAI_API_KEY=
# Output-cap param + value for the OpenAI call. gpt-5.x needs max_completion_tokens;
# older chat models need max_tokens. Override the yaml config without editing it:
# CIO_OPENAI_TOKEN_PARAM=max_completion_tokens   # or: max_tokens
# CIO_OPENAI_MAX_TOKENS=2048

# NVIDIA NIM (committee agents set to service: nim) — get a key at build.nvidia.com
NVIDIA_API_KEY=
# NIM output-cap value (overrides nim.max_tokens in yaml):
# CIO_NIM_MAX_TOKENS=2048
# NIM request timeout seconds (default 300). Large models like nemotron-550B can
# take >120s under concurrent load; increase if you see ReadTimeout warnings.
# CIO_NIM_TIMEOUT=300
# Claude (claude-agent-sdk) has no plain output max_tokens — only a thinking-token
# budget. Set to cap thinking (unset = SDK default):
# CIO_CLAUDE_MAX_THINKING_TOKENS=8000
# Committee execution: on = parallel (default), off = one agent at a time
# CIO_PARALLEL=on
# CIO_MAX_CONCURRENCY=8
# CIO_MODELS_CONFIG=config/committee_models.yaml

# Optional: pin the model the agent uses (defaults to Claude Code's default).
# CIO_MODEL=claude-haiku-4-5
# CFO_MODEL=claude-haiku-4-5  # still honored as fallback

# --- Developer dashboard (python -m cio.dashboard) -------------------------
# Localhost-only, read-only web view to verify the agent: token usage, Telegram
# history, and the full committee sent/returned transcript.
# Capture level (default 1): how much the dashboard records.
#   1 = full capture, committee transcript pruned to last CIO_TRANSCRIPT_KEEP_RUNS, Telegram ON
#   2 = full capture, no pruning (keep everything forever)
#   3 = committee only — Telegram history OFF
# CIO_CAPTURE_LEVEL=1
# CIO_TRANSCRIPT_KEEP_RUNS=200
# CIO_DASH_HOST=127.0.0.1
# CIO_DASH_PORT=8787
# CIO_DASH_TOKEN=          # optional shared secret; append ?token=... in the browser

# --- Web search / fetch (Firecrawl) ----------------------------------------
# The agent's web_search / web_scrape tools call a Firecrawl instance. Defaults to
# a self-hosted server on localhost:3002 (no key needed). Point at Firecrawl cloud
# by setting CIO_FIRECRAWL_URL + FIRECRAWL_API_KEY instead.
# CIO_FIRECRAWL_URL=http://localhost:3002   # falls back to FIRECRAWL_API_URL
# FIRECRAWL_API_KEY=                         # only for cloud / authed instances
# CIO_WEB_MAX_CHARS=6000   # per-result markdown cap (protects the prompt budget)
# CIO_WEB_TIMEOUT=45       # request timeout seconds

# --- Structured market data (optional, opt-in) -----------------------------
# Two extra sources that enrich the committee bundle + WMA briefing with
# primary-source filings and analyst/earnings data. Both are OFF until you set
# the value below; unset = no network call and no behavior change (the test
# suite stays fully offline by default).
#
# SEC EDGAR — official filings: 8-K material events (acquisitions, CEO changes,
# buybacks, guidance), plus 10-Q / 10-K reports. No API key, but the SEC's
# fair-access policy REQUIRES a User-Agent that identifies you. Set it to
# "AppName Your Name your-email" to enable EDGAR lookups. A fresh 8-K also
# auto-escalates a watchlist name to the full committee.
# CIO_SEC_UA=CIOAgent Your Name you@example.com
#
# Finnhub — analyst recommendation trends, earnings calendar, company news,
# earnings surprises (Alpha Hunter). Free tier = 60 calls/min. Get a key at
# finnhub.io. Unset = Finnhub disabled (no network call; surprise score = 0).
# FINNHUB_API_KEY=
#
# FRED (St. Louis Fed) — Treasury yield curve (DGS2/10/30, 2s10s inversion) + HY
# credit spread (BAMLH0A0HYM2) for the daily market brief's macro-regime line.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html  Cached 6h, low
# volume. Unset = FRED disabled (no network call; brief renders breadth-only).
# FRED_API_KEY=
#
# GDELT — global news headlines + tone/volume per watchlist name. Keyless and
# FREE, so it is the one source ENABLED BY DEFAULT (powers the news-spike alert
# and the brief's headline count). Set to 0/false to disable. Always offline-safe
# (network failure -> no headlines, no error).
# CIO_GDELT_ENABLED=1
#
# HTTP read/connect timeout (seconds) for cio.data GETs (finnhub/EDGAR/etc).
# Raise it if you see "data.get_json failed: read operation timed out" on a slow
# upstream (e.g. finnhub /stock/earnings under the free tier). Default 15.
# CIO_HTTP_TIMEOUT=30
#
# Interactive Brokers — live portfolio (read-only) via the TWS API socket of a
# running Trader Workstation / IB Gateway (library: ib_async). Setup in TWS:
# Global Configuration → API → Settings → Enable ActiveX and Socket Clients,
# and turn on "Read-Only API". Ports: TWS live 7496 / paper 7497; IB Gateway
# live 4001 / paper 4002. Unset = IBKR disabled (no network call). The bot
# connects readonly=True and only READS positions/cash — it cannot trade.
# CIO_IBKR_TWS=127.0.0.1:7496
# CIO_IBKR_ACCOUNT=     # optional: pin one account id; default = first account
# CIO_IBKR_CLIENT_ID=17 # optional: API client id, unique per TWS connection
#
# Where EDGAR/Finnhub responses are cached (default: data/data_cache).
# CIO_DATA_CACHE_DIR=
#
# ClinicalTrials.gov request timeout (seconds, default 20). No API key needed.
# CIO_CT_TIMEOUT=20
#
# Mirror logs to a date-based file on disk (logs/cio-YYYY-MM-DD.log) — includes
# the cio.evidence lines that confirm which primary-source tools fired. When set,
# this OVERRIDES and locks the Configure-tab toggle (1/true/yes/on = file logging).
# Leave unset to control it from the dashboard Configure tab instead.
# CIO_LOG_TO_FILE=0
# CIO_LOG_DIR=        # default: <project>/logs

# Local timezone (IANA name) for dashboard timestamps + the token-usage day
# boundary. Default America/Vancouver.
# CIO_TZ=America/Vancouver

# Daily digest time (local timezone). Set CIO_DIGEST_HOUR=off to disable.
# CIO_DIGEST_HOUR=8
# CIO_DIGEST_MINUTE=0
# CFO_DIGEST_HOUR / CFO_DIGEST_MINUTE still honored as fallback (back-compat)

# Watchlist Monitoring Agent (WMA) — pre-market briefing on the active watchlist.
# Pushed to subscribed chats; also runnable on demand via Telegram /briefing.
# Default 06:00 local on stock days. Set CIO_WMA_HOUR=off to disable.
# Nasdaq holidays AND weekends are always skipped (NYSE calendar), so the run
# only fires on real trading days regardless of CIO_WMA_DAYS.
# CIO_WMA_HOUR=6
# CIO_WMA_MINUTE=0
# CIO_WMA_DAYS=mon-fri          # cron day_of_week prefilter (e.g. mon-fri, mon,wed,fri)
# CIO_WMA_CONCURRENCY=4         # securities analysed in parallel

# News-spike alert — intraday scan for an UNSCHEDULED news surge on a watchlist
# name (GDELT article volume vs its 7-day baseline). Complements the dated econ
# alert. OFF by default: set CIO_SPIKE_EVERY_MIN to a minute interval (>=5) to arm
# it. cio.alerts dedups so a surge alerts once, not every tick. Needs no API key
# (GDELT is keyless; Finnhub enriches sources if set).
# CIO_SPIKE_EVERY_MIN=30        # off = disabled (default); e.g. 30 = scan every 30 min
# CIO_SPIKE_MIN_COUNT=5         # min articles in the 2h window to qualify
# CIO_SPIKE_MULT=3              # window must be >= this x the 7-day baseline
# CIO_SPIKE_MIN_SOURCES=2       # min distinct news sources
# CIO_SPIKE_COOLDOWN_MIN=30     # per-catalyst dedup window (minutes)
